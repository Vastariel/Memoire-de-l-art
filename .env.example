# Copy this file to .env and fill in the values before running docker compose up

# ── Ports ────────────────────────────────────────────────────────
PORT_API=3000
PORT_ADMIN=3001
PORT_MINIO_API=9000
PORT_MINIO_CONSOLE=9001

# ── Secrets ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
JWT_SECRET=change_me_at_least_32_chars_long_secret_key
MINIO_ACCESS_KEY=mda_admin
MINIO_SECRET_KEY=change_me_minio_password
ADMIN_TOKEN=change_me_admin_secret_token

# ── CORS — liste les origines autorisées (séparées par des virgules) ──
# Mettre l'URL du panel admin telle qu'elle sera accédée depuis le navigateur
CORS_ORIGINS=http://localhost:3001
